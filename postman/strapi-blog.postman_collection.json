                },
                {
                  "key": "pagination[pageSize]",
                  "value": "12"
                },
                {
                  "key": "sort",
                  "value": "publishedAt:desc"
                }
              ]
            }
          }
        },
        {
          "name": "Get Article By ID (safe/full by unlock token)",
