{
  "kind": "collectionType",
  "collectionName": "knowledge_nodes",
  "info": {
    "singularName": "knowledge-node",
    "pluralName": "knowledge-nodes",
    "displayName": "Knowledge Node"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::knowledge-node.knowledge-node",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::knowledge-node.knowledge-node",
      "mappedBy": "parent"
    },
    "depth": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "sort": {
      "type": "integer",
      "default": 0
    },
    "posts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article",
      "mappedBy": "wikiNodes"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
