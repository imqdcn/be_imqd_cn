{
  "kind": "collectionType",
  "collectionName": "quiz_sets",
  "info": {
    "singularName": "quiz-set",
    "pluralName": "quiz-sets",
    "displayName": "Quiz Set"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "difficulty": {
      "type": "enumeration",
      "enum": [
        "easy",
        "medium",
        "hard"
      ],
      "default": "medium"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::quiz-item.quiz-item",
      "mappedBy": "quizSet"
    },
    "posts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "quizSet"
    }
  }
}
